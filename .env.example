# LLM provider: "ollama" (default) or "claude"
LLM_PROVIDER=ollama

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:26b

# Claude settings (only used when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=your-key-here

# Scryfall
SCRYFALL_BASE_URL=https://api.scryfall.com
# Scryfall requests must be at most 10/sec; this adds a small delay between calls
SCRYFALL_RATE_LIMIT_DELAY=0.1
